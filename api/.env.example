# ============================================================
# BR10ACS — Variáveis de Ambiente
# ============================================================

# Aplicação
NODE_ENV=development
PORT=3000
APP_NAME=BR10ACS

# MongoDB — banco br10 (separado do banco genieacs)
MONGODB_URI=mongodb://localhost:27017/br10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=br10acs_jwt_secret_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=br10acs_refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# GenieACS NBI (API REST — nunca acesso direto ao banco)
GENIEACS_NBI_URL=http://localhost:7557
GENIEACS_NBI_USERNAME=
GENIEACS_NBI_PASSWORD=

# GenieACS CWMP
GENIEACS_CWMP_URL=http://localhost:7547

# Criptografia de senhas/tokens de integração
ENCRYPTION_KEY=br10acs_enc_key_32chars_change_me

# Sessão
SESSION_SECRET=br10acs_session_secret_change_in_production
SESSION_EXPIRE_SECONDS=3600

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

# Logs
LOG_LEVEL=info
