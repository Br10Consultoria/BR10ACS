# =============================================================================
# BR10ACS — .env.example
#
# Copie este arquivo para .env e ajuste os valores:
#   cp .env.example .env
#
# ATENÇÃO: O script instalar.sh preenche automaticamente as senhas
# criptografadas. Você só precisa ajustar as variáveis marcadas com (*)
# =============================================================================

# ─── Aplicação ────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_NAME=BR10ACS
TZ=America/Sao_Paulo

# ─── Portas públicas ──────────────────────────────────────────────────────────
# Porta da interface web / API do BR10ACS
API_PORT=8080
# Porta CWMP (TR-069) — deve ser acessível pelas ONTs
CWMP_PORT=7547

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Usuário root do MongoDB (criado automaticamente)
MONGO_ROOT_USER=admin
# Senha root — gerada automaticamente pelo instalar.sh
MONGO_ROOT_PASSWORD=GERADA_AUTOMATICAMENTE

# CPUs sem suporte a AVX (VMs antigas, Proxmox sem AVX, KVM antigo):
# Descomente a linha abaixo para usar MongoDB 4.4 (compatível sem AVX)
# MONGO_IMAGE=mongo:4.4
#
# CPUs modernas com AVX (padrão):
MONGO_IMAGE=mongo:7

# ─── Redis ────────────────────────────────────────────────────────────────────
# Senha do Redis — gerada automaticamente pelo instalar.sh
REDIS_PASSWORD=GERADA_AUTOMATICAMENTE

# ─── JWT / Segurança ──────────────────────────────────────────────────────────
# Segredos JWT — gerados automaticamente pelo instalar.sh
JWT_SECRET=GERADO_AUTOMATICAMENTE
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=GERADO_AUTOMATICAMENTE
JWT_REFRESH_EXPIRES_IN=7d

# ─── Criptografia ─────────────────────────────────────────────────────────────
# Chave de 32 chars para criptografar tokens de integração — gerada automaticamente
ENCRYPTION_KEY=GERADO_AUTOMATICAMENTE

# ─── Sessão ───────────────────────────────────────────────────────────────────
SESSION_SECRET=GERADO_AUTOMATICAMENTE
SESSION_EXPIRE_SECONDS=3600

# ─── CORS ─────────────────────────────────────────────────────────────────────
# (*) Adicione o IP/domínio do seu servidor
# Exemplo: CORS_ORIGINS=http://192.168.1.100:8080,https://acs.suaempresa.com.br
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# ─── GenieACS ─────────────────────────────────────────────────────────────────
# Credenciais opcionais para autenticação na NBI (se configurado no GenieACS)
GENIEACS_NBI_USERNAME=
GENIEACS_NBI_PASSWORD=

# ─── Coletor de dados ─────────────────────────────────────────────────────────
# Intervalo de coleta de telemetria em segundos (padrão: 5 minutos)
COLLECTOR_INTERVAL=300
# Intervalo de histórico em segundos (padrão: 1 hora)
COLLECTOR_HISTORY_INTERVAL=3600
# Tempo para marcar dispositivo como offline em segundos (padrão: 15 minutos)
COLLECTOR_OFFLINE_AFTER=900

# ─── Logs ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Swagger ──────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

# ─── OpenAI (opcional — para Análise IA) ──────────────────────────────────────
# (*) Pode ser configurado também pela interface web em: Análise IA → Configurar IA
# OPENAI_API_KEY=sk-proj-...
# OPENAI_API_BASE=https://api.openai.com/v1

# ─── Telegram Bot (opcional) ──────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ─── WhatsApp Business (opcional) ─────────────────────────────────────────────
# WHATSAPP_API_URL=
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# ─── Atualização do Sistema ───────────────────────────────────────────────────
# Caminho absoluto do repositório no host (usado pelo container para git pull)
# Gerado automaticamente pelo instalar.sh — não altere manualmente
PROJECT_DIR=/opt/BR10ACS
